# ============ AI Models ============
# Z.AI API Key (required for ChainCashier checkout agent / GLM-5.1)
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# DeepSeek API Key (default provider)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# Zhipu API Key
ZHIPU_API_KEY=
BASE_URL=

# Qwen API Key (legacy optional)
QWEN_API_KEY=
QWEN_BASE_URL=

# OpenAI API Key (fallback)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic API Key (fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ============ LI.FI Configuration ============
# Optional server-side LI.FI API Key (from https://portal.li.fi/)
LIFI_API_KEY=

# LI.FI Earn Data API Base URL
NEXT_PUBLIC_LIFI_EARN_DATA_URL=https://earn.li.fi

# ============ Wallet Configuration ============
# WalletConnect Project ID (from https://cloud.walletconnect.com/)
# Required for RainbowKit to show multi-brand wallets such as WalletConnect and Coinbase Wallet.
NEXT_PUBLIC_WC_PROJECT_ID=

# ============ Optional: Per-Agent Model Override ============
MAIN_AGENT_MODEL=deepseek/deepseek-v4-pro
CHECKOUT_AGENT_MODEL=zai/glm-5.1
EARNING_AGENT_MODEL=deepseek/deepseek-v4-pro
BRIDGE_AGENT_MODEL=deepseek/deepseek-v4-pro
RISK_AGENT_MODEL=deepseek/deepseek-v4-pro
MONITOR_AGENT_MODEL=deepseek/deepseek-v4-pro
